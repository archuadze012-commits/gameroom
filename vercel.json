{
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/admin/cron/unban-expired",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/admin/cron/reengage",
      "schedule": "0 9 * * *"
    }
  ],
  "functions": {
    "src/app/api/chatbot/route.ts": { "maxDuration": 30 },
    "src/app/api/moderate/route.ts": { "maxDuration": 30 },
    "src/app/api/lfg/route.ts": { "maxDuration": 30 },
    "src/app/api/lfg-assist/route.ts": { "maxDuration": 30 },
    "src/app/api/smart-replies/route.ts": { "maxDuration": 30 },
    "src/app/api/skill-assess/route.ts": { "maxDuration": 30 },
    "src/app/api/tournament-summary/route.ts": { "maxDuration": 30 },
    "src/app/api/bracket-generate/route.ts": { "maxDuration": 30 },
    "src/app/api/translate/route.ts": { "maxDuration": 30 },
    "src/app/api/auth/steam/callback/route.ts": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
