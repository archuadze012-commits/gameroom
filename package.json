    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "pm:seed:eafc26": "EAFC26_IMPORT_LIMIT=1000 node --env-file=.env.local scripts/seed-eafc26-all-players.mjs",
    "pm:seed:eafc26:all": "node --env-file=.env.local scripts/seed-eafc26-all-players.mjs"
  },
