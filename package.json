    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "ttf2woff2": "^8.0.1",
    "tw-animate-css": "^1.4.0",
