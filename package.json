{
  "name": "gameroom",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "node --import tsx --test --experimental-test-module-mocks --disable-warning=ExperimentalWarning 'src/**/*.test.ts'",
