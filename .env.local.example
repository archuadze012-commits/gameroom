# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database
# Transaction pooler (port 6543) — used by the app at runtime
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — used by Drizzle migrations only
DATABASE_DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Public site URL — MUST match the deployed domain in Vercel dashboard (Production scope)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI — Groq (chatbot, moderation, smart-replies, skill-assess, translate, lfg-assist)
GROQ_API_KEY=gsk_...

# Linked accounts
STEAM_API_KEY=
RIOT_API_KEY=

# Web push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@gameroom.com.ge

# Email (Resend) — for admin email blast
RESEND_API_KEY=
RESEND_FROM=Gameroom <noreply@gameroom.com.ge>

# YouTube / TikTok (optional content integrations)
YOUTUBE_API_KEY=
TIKTOK_ACCESS_TOKEN=

# Bootstrap admin access (comma-separated emails)
ADMIN_EMAILS=you@example.com

# Cron endpoint protection — generate with: openssl rand -hex 32
CRON_SECRET=
