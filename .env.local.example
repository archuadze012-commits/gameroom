# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct Postgres connection (for Drizzle migrations + server queries)
# Use Supabase's Connection Pooler "Session" URL for app code,
# and the "Direct" URL for migrations.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Public site URL (used in auth callbacks and OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
