NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=
ADMIN_EMAILS=
DATABASE_URL=
DATABASE_DIRECT_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MCP_ACCESS_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Optional: YouTube Data API v3 key — enables reliable LIVE-stream detection on the
# home hero carousel (auto-detects which profiles' youtube_handle is live now).
# Unset = falls back to scraping the public /live page.
YOUTUBE_API_KEY=
# Optional: webhook (e.g. Discord) for logger.critical alerts. Unset = alerts disabled.
ALERT_WEBHOOK_URL=
# Optional scripts (scratch/): old project DB connection for data migration helpers.
OLD_DATABASE_URL=
# Optional: Sentry error tracking. Unset = Sentry SDK no-ops everywhere (init()
# with an empty dsn is a safe no-op). Get these from sentry.io after creating a
# free Developer-tier project (Platform: Next.js).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional: only needed to enable readable stack traces (source-map upload) at
# build time. Create at sentry.io -> Settings -> Auth Tokens (scope: project:releases).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
