# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local
.agents/
.codex/
.env
/artifacts/

# scratch / one-off scripts
/scratch/

# MCP config (contains API tokens)
.mcp.json
