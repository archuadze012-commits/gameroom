# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.*.log

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local
.agents/
.codex/
.env
/artifacts/
/ComfyUI/

# scratch / one-off scripts
/scratch/

# MCP config (contains API tokens)
.mcp.json

certificates

# logs
*.log

# one-off / scratch scripts at repo root
/find_actions*.js
/fix_page.js
/find_missing_exports.js

# tooling temp output
.codex_tmp*
.tmp/
/meshy_output/

# Supabase CLI local state (linked project ref, machine-local)
/supabase/.temp/

# local editor / agent config (not shared)
.vscode/
.claude/settings.local.json
.claude/agents/
.claude/skills/
# NOTE: .claude/agent-memory/ is intentionally TRACKED (agent memory must travel)

